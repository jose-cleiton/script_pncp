# =============================================================================
# .env.example — copie este arquivo para .env e preencha os valores
#
#   cp .env.example .env
#
# NUNCA faça commit do .env — ele está no .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Chaves de API para classificação LLM (Etapa 5 — classificar_gpt)
# Preencha APENAS a chave do provedor que for usar.
# -----------------------------------------------------------------------------

# OpenAI — obtenha em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — obtenha em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# -----------------------------------------------------------------------------
# Configurações da API PNCP (opcional — sobrescreve os defaults do pipeline)
# -----------------------------------------------------------------------------

# URL base da API do PNCP (não altere sem necessidade)
PNCP_BASE_URL=https://pncp.gov.br/api/consulta

# Código da modalidade de contratação
# 6 = Pregão Eletrônico (padrão)
PNCP_CODIGO_MODALIDADE=6

# Quantidade de registros por página (máx. permitido pela API: 50)
PNCP_TAMANHO_PAGINA=50
